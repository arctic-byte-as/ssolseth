# Local server environment variables
JWT_SECRET=change_this
# optional SMTP settings for password reset emails
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=username
SMTP_PASS=password
SMTP_FROM="Time Tracker <no-reply@example.com>"
# optional frontend reset page URL if using an external frontend host
FRONTEND_RESET_URL=http://localhost:4000/reset.html
